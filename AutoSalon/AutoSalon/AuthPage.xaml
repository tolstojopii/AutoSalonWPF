<Page x:Class="AutoSalon.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Авторизация">
    <Grid Background="Orange">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Логин:" Width="100" Margin="5" VerticalAlignment="Center" TextAlignment="Right"/>
                <TextBox x:Name="TBoxLogin" Width="150" Margin="5"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Пароль:" Width="100" Margin="5" VerticalAlignment="Center" TextAlignment="Right"/>
                <PasswordBox x:Name="TBoxPassword" Width="150" Margin="5"/>
            </StackPanel>
            <Button Content="Войти" Width="100" Height="30" Margin="5" HorizontalAlignment="Right" Click="BtnLogin_Click"/>
        </StackPanel>
    </Grid>
</Page>