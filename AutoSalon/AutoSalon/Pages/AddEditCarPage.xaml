<Page x:Class="AutoSalon.Pages.AddEditCarPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Автомобиль" Height="450" Width="600">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Название:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="TitleTextBox" Grid.Row="0" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Производитель:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <ComboBox x:Name="ManufacturerComboBox" Grid.Row="1" Grid.Column="1" Margin="5"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <TextBlock Text="Цена:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="CostTextBox" Grid.Row="2" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Описание:" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Top"/>
        <TextBox x:Name="DescriptionTextBox" Grid.Row="3" Grid.Column="1" Margin="5" Height="80" TextWrapping="Wrap"/>

        <TextBlock Text="Активен:" Grid.Row="4" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <CheckBox x:Name="IsActiveCheckBox" Grid.Row="4" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>

        <TextBlock Text="Главное фото:" Grid.Row="5" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="5">
            <Image x:Name="CarImage" Width="100" Height="100" Stretch="Uniform" Margin="0,0,10,0"/>
            <Button Content="Выбрать фото" Click="SelectImageButton_Click" Width="100"/>
        </StackPanel>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button Content="Сохранить" Click="SaveButton_Click" Width="80" Margin="5"/>
            <Button Content="Отмена" Click="CancelButton_Click" Width="80" Margin="5"/>
        </StackPanel>
    </Grid>
</Page>