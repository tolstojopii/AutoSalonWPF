<Page x:Class="AutoSalon.Pages.SalesListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Продажи">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Продажи автомобилей" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="SalesDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Дата продажи" Binding="{Binding Saledate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Автомобиль" Binding="{Binding Product.Title}" Width="200"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding Client.FIO}" Width="200"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalCost, StringFormat=C}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Обновить" Click="RefreshButton_Click" Width="80" Margin="5"/>
            <Button Content="Добавить продажу" Click="AddSaleButton_Click" Width="120" Margin="5"/>
            <Button Content="Закрыть" Click="CloseButton_Click" Width="80" Margin="5"/>
        </StackPanel>
    </Grid>
</Page>