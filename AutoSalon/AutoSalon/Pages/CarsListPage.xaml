<Page x:Class="AutoSalon.Pages.CarsListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Автомобили">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель фильтров -->
        <StackPanel Orientation="Horizontal" Margin="10" HorizontalAlignment="Center">
            <TextBlock Text="Поиск:" VerticalAlignment="Center"/>
            <TextBox x:Name="SearchTextBox" Width="150" Margin="5,0" TextChanged="SearchTextBox_TextChanged"/>
            <TextBlock Text="Производитель:" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <ComboBox x:Name="ManufacturerFilterComboBox" Width="150" Margin="5,0" SelectionChanged="Filter_Changed"
                      DisplayMemberPath="Name" SelectedValuePath="Id"/>
            <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <ComboBox x:Name="SortComboBox" Width="150" Margin="5,0" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="По названию (А-Я)"/>
                <ComboBoxItem Content="По цене (возрастание)"/>
                <ComboBoxItem Content="По цене (убывание)"/>
            </ComboBox>
            <Button Content="Обновить" Width="80" Margin="10,0,0,0" Click="RefreshButton_Click"/>
        </StackPanel>

        <!-- Список автомобилей -->
        <ScrollViewer Grid.Row="1" Margin="10">
            <ItemsControl x:Name="CarsItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Black" BorderThickness="1" Margin="5" Padding="5" Width="300">
                            <StackPanel>
                                <Image Source="{Binding MainImagePath}" Height="150" Stretch="Uniform"/>
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" Margin="0,5"/>
                                <TextBlock Text="{Binding Manufacturer.Name, StringFormat='Производитель: {0}'}"/>
                                <TextBlock Text="{Binding Cost, StringFormat='Цена: {0:C}'}"/>
                                <TextBlock Text="{Binding IsActiveText}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10"
                   x:Name="RecordsCountTextBlock" Foreground="Gray"/>
    </Grid>
</Page>