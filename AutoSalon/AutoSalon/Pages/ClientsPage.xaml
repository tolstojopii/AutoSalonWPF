<Page x:Class="AutoSalon.Pages.ClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Клиенты">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Label Content="Поиск:" VerticalAlignment="Center"/>
            <TextBox x:Name="SearchTextBox" Width="150" Margin="5,0" TextChanged="SearchTextBox_TextChanged"/>
            <Label Content="Пол:" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <ComboBox x:Name="GenderFilterComboBox" Width="100" Margin="5,0" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="Все"/>
                <ComboBoxItem Content="Мужской"/>
                <ComboBoxItem Content="Женский"/>
            </ComboBox>
            <Button Content="Обновить" Width="80" Margin="10,0,0,0" Click="RefreshButton_Click"/>
        </StackPanel>

        <DataGrid x:Name="ClientsDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FIO}" Width="200"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                <DataGridTextColumn Header="Пол" Binding="{Binding GendercodeNavigation.Name}" Width="80"/>
                <DataGridTextColumn Header="Дата регистрации" Binding="{Binding Registrationtime, StringFormat=dd.MM.yyyy}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Удалить" Click="DeleteButton_Click" Width="80" Margin="5" Background="LightCoral"/>
            <Button Content="Закрыть" Click="CloseButton_Click" Width="80" Margin="5"/>
        </StackPanel>
    </Grid>
</Page>