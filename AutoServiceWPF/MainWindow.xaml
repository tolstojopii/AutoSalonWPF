<Window x:Class="AutoServiceWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutoServiceWPF"
        mc:Ignorable="d"
        Title="Главная страница лучшего автосалона" Height="450" Width="800">
    <Grid Background="Orange">
        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <Grid Background="#2c2c2c"/>
        <Frame Grid.Row="1" x:Name="FrameMain" NavigationUIVisibility="Hidden" ContentRendered="FrameMain_ContentRendered"/>
        <Image HorizontalAlignment="Right" VerticalAlignment="Center" Source="/Pages/Preview.jpg" />
        <TextBlock Text="Лучший автосервис" Foreground="White" FontFamily="Comic Sans MS" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="24" Margin="10 0 0 0" />
        <Button Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center" Width="100" Height="40" Content="Авторизация" Margin="5" Padding="5" x:Name="BtnLogin" Click="BtnLogin_Click"/>
        <Button Content="Назад" Width="100" Height="40" Grid.Row="2" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5" Padding="5" x:Name="BtnBack" Click="BtnBack_Click"/>
    </Grid>
</Window>
