<Page x:Class="AutoServiceWPF.Pages.EditServicePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AutoServiceWPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EditServicePage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Grid Background="#2c2c2c" Grid.ColumnSpan="3">
            <TextBlock Margin="5" Text="Лучший автосервис" Foreground="White" FontFamily="Comic Sans MS" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="24"/>
            <Image HorizontalAlignment="Right" VerticalAlignment="Center" Source="/Pages/Preview.jpg" />
        </Grid>

        <DataGrid Grid.Row="1" Margin="10" Grid.ColumnSpan="3" x:Name="dtGridServices" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Width="*" Binding="{Binding Title}" Header="Название"/>
                <DataGridTextColumn Width="*" Binding="{Binding Cost}" Header="Стоимость"/>
                <DataGridTextColumn Width="*" Binding="{Binding Discount}" Header="Скидка"/>
                <DataGridTextColumn Width="*" Binding="{Binding Durationinservice}" Header="Длительность работы"/>
            </DataGrid.Columns>
        </DataGrid>
        <Button x:Name="BtnAdd" Content="Добавить" Click="BtnAdd_Click"  Grid.Row="2" Grid.ColumnSpan="3" FontSize="18" Margin="10 0 10 5" Width="150"/>
        <Button x:Name="BtnEdit" Content="Редактировать" Click="BtnEdit_Click"  Grid.Row="2" Grid.ColumnSpan="3" FontSize="18" Margin="10 0 10 5" Width="150" HorizontalAlignment="Left"/>
        <Button x:Name="BtnDelete" Content="Удалить" Click="BtnDelete_Click"  Grid.Row="2" Grid.ColumnSpan="3" FontSize="18" Margin="10 0 10 5" Width="150" HorizontalAlignment="Right"/>
    </Grid>
</Page>
