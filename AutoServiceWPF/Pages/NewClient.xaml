<Page x:Class="AutoServiceWPF.Pages.NewClient"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AutoServiceWPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="NewClient">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Background="#2c2c2c" Grid.ColumnSpan="2">
            <TextBlock Margin="5" Text="Лучший автосервис" Foreground="White" FontFamily="Comic Sans MS" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="24"/>
            <Image HorizontalAlignment="Right" VerticalAlignment="Center" Source="/Pages/Preview.jpg" />
        </Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Row="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Услуга:" Margin="5" Width="150" VerticalAlignment="Center" TextAlignment="Right"/>
                <ComboBox Width="250" Margin="5" Name="CmBoxService" DisplayMemberPath="NameAndDuration"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Клиент:" Margin="5" VerticalAlignment="Center" TextAlignment="Right" Width="150"/>
                <ComboBox Margin="5" Width="250" Name="CmBoxClient" DisplayMemberPath="FIO"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Дата оказания:" Margin="5" Width="150" TextAlignment="Right" VerticalAlignment="Center"/>
                <DatePicker Width="250" Margin="5" Name="DatePickerStartDate"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Часы:" Margin="5" Width="150" VerticalAlignment="Center" TextAlignment="Right"/>
                <TextBox Width="90" Margin="5" Name="TBoxStartHour" MaxLength="2"/>
                <TextBlock Text="Минуты:" Margin="5" Width="50" VerticalAlignment="Center" TextAlignment="Right"/>
                <TextBox Width="90" Margin="5" Name="TBoxStartMinute" MaxLength="2"/>
            </StackPanel>
            <Button Content="Записать" Width="250" Margin="5" HorizontalAlignment="Right" Height="30" Name="BtnWriteClient" Click="BtnWriteClient_Click"/>
        </StackPanel>
    </Grid>
</Page>
