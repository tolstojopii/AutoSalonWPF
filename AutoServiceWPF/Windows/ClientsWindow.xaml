<Window x:Class="AutoServiceWPF.Views.ClientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клиенты автосалона" Height="500" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Поиск -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Label Content="Поиск:" VerticalAlignment="Center"/>
            <TextBox x:Name="SearchTextBox" Width="200" Margin="5,0" TextChanged="SearchTextBox_TextChanged"/>
            <Label Content="Фильтр по полу:" VerticalAlignment="Center" Margin="15,0,0,0"/>
            <ComboBox x:Name="GenderFilterComboBox" Width="100" Margin="5,0" SelectionChanged="GenderFilterComboBox_SelectionChanged">
                <ComboBoxItem Content="Все"/>
                <ComboBoxItem Content="Мужской"/>
                <ComboBoxItem Content="Женский"/>
            </ComboBox>
            <Label Content="Сортировка:" VerticalAlignment="Center" Margin="15,0,0,0"/>
            <ComboBox x:Name="SortComboBox" Width="150" Margin="5,0" SelectionChanged="SortComboBox_SelectionChanged">
                <ComboBoxItem Content="По фамилии (А-Я)"/>
                <ComboBoxItem Content="По дате регистрации (новые сначала)"/>
                <ComboBoxItem Content="По дате регистрации (старые сначала)"/>
            </ComboBox>
            <Button Content="Обновить" Width="80" Margin="15,0,0,0" Click="RefreshButton_Click"/>
        </StackPanel>

        <!-- DataGrid с клиентами -->
        <DataGrid x:Name="ClientsDataGrid" Grid.Row="3" AutoGenerateColumns="False" IsReadOnly="True" 
                  SelectionMode="Single" SelectionUnit="FullRow" Margin="0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FIO}" Width="200"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                <DataGridTextColumn Header="Пол" Binding="{Binding GendercodeNavigation.Name}" Width="80"/>
                <DataGridTextColumn Header="Дата регистрации" Binding="{Binding Registrationtime, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="DeleteButton" Content="Удалить выбранного клиента" Width="180" Height="30" Margin="5" Click="DeleteButton_Click" Background="LightCoral"/>
            <Button Content="Закрыть" Width="80" Height="30" Margin="5" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>