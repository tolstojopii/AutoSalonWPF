<Window x:Class="AutoServiceWPF.Windows.EditServiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutoServiceWPF.Windows"
        mc:Ignorable="d"
        Title="EditServiceWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid Background="#2c2c2c" Grid.ColumnSpan="3">
            <TextBlock Margin="5" Text="Лучший автосервис" Foreground="White" FontFamily="Comic Sans MS" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="24"/>
            <Image HorizontalAlignment="Right" VerticalAlignment="Center" Source="/Pages/Preview.jpg" />
        </Grid>

        <DataGrid Grid.Row="1" Margin="10" Grid.ColumnSpan="3" x:Name="DGridServices" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Width="*" Binding="{Binding Title}" Header="Название"/>
                <DataGridTextColumn Width="*" Binding="{Binding Cost}" Header="Стоимость"/>
                <DataGridTextColumn Width="*" Binding="{Binding Discount}" Header="Скидка"/>
                <DataGridTextColumn Width="*" Binding="{Binding Durationinservice}" Header="Длительность работы"/>
            </DataGrid.Columns>
        </DataGrid>
        <Button HorizontalAlignment="Left" Margin="5" VerticalAlignment="Center" Grid.Row="2" Width="150" Height="30" Content="Редактировать" Name="BtnEdit" Click="BtnEdit_Click"/>
        <Button HorizontalAlignment="Right" Margin="5" VerticalAlignment="Center" Grid.Row="2" Width="150" Height="30" Content="Удалить" Name="BtnDelete" Click="BtnDelete_Click"/>
    </Grid>
</Window>
